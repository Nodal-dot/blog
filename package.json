        "analyze": "cross-env ANALYZE=true next build",
        "prepare": "husky",
        "type-check": "tsc --noEmit"
    },
    "dependencies": {
        "@gsap/react": "^2.1.2",
        "gray-matter": "^4.0.3",
        "gsap": "^3.13.0",
        "next": "^15.5.7",
        "next-intl": "^4.3.4",
        "next-mdx-remote": "^6.0.0",
        "prismjs": "^1.30.0",
        "react": "19.1.0",
        "react-dom": "19.1.0",
        "remark-gfm": "^4.0.1",
        "sass": "^1.89.2",
        "swiper": "^12.0.3",
        "three": "^0.182.0"
    },
    "devDependencies": {
        "@eslint/eslintrc": "^3",
        "@eslint/js": "^9.33.0",
        "@next/bundle-analyzer": "^16.0.5",
