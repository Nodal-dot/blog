{
    "name": "blog",
    "version": "0.1.0",
    "private": true,
    "scripts": {
        "dev": "next dev --turbopack",
        "build": "next build",
        "start": "next start",
        "lint": "eslint src/",
        "lint:fix": "eslint src/ --fix",
        "format": "prettier --check .",
        "format:fix": "prettier --write .",
        "test": "jest",
        "storybook": "storybook dev -p 6006",
